{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kaleidomo",
  "version": "0.9.13",
  "identifier": "com.kaleidomo.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Kaliedomo",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      },
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' asset: http://asset.localhost https://asset.localhost blob: data: filesystem:; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost http://tauri.localhost; script-src 'self';"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "signCommand": "trusted-signing-cli -e https://eus.codesigning.azure.net/ -a HyperformanceSolutions -c AlteredBrainChemistry1 -d Kaleidomo %1"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
